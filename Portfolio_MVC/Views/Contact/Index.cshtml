                                            @Html.TextBox("Email", null, new { @class = "form-control", required = "required" })
                                        </div>

                                        <div class="col-md-12">
                                            <label for="subject-field" class="pb-2">Subject</label>
                                           
                                            @Html.TextBox("Subject", null, new { @class = "form-control", required = "required" })
                                        </div>

                                        <div class="col-md-12">
                                            <label for="message-field" class="pb-2">Message</label>
                                            @*@Html.TextArea("Message")*@
                                            @Html.TextArea("Message", null, new { @class = "form-control", rows = "10", required = "required" })
                                        </div>

                                        <div class="col-md-12 text-center">
                                            <input type="submit" value="Send Message" class="btn-send" />
                                        </div>

