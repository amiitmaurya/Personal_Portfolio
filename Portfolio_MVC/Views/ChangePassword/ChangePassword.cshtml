@model Portfolio_MVC.Models.ChangePasswordViewModel
@{
    ViewBag.Title = "ChangePassword";
}



<script>
    function togglePwd(id) {
        var input = document.getElementById(id);
        input.type = input.type === "password" ? "text" : "password";
    }
</script>

