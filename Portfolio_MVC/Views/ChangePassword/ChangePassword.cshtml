        <style>
            /* ⭐⭐ ADD THIS ⭐⭐ */

            /* ⭐⭐ SCROLL BAR REMOVE ⭐⭐ */
            html, body {
                height: 100%;
                overflow: hidden; /* 🔥 scroll bar remove */
            }


            .main-page {
                position: fixed; /* 🔥 screen se chipka rahe */
                top: 25px;
                left: 0;
                width: 100%;
                height: 100vh;

                min-height: 100vh; /* full screen height */
                display: flex; /* flex enable */
                justify-content: center; /* horizontal center */
                align-items: center; /* vertical center */
            }
            .cp-container {
                width: 380px;
                margin: 0; /* ⭐ CHANGE */
            }

            /* ===== CLASSIC CONTAINER ===== */
            .cp-container {
                width: 380px;
                margin: 60px auto;
                padding: 25px;
                border: 1px solid #ccc;
                border-radius: 6px;
                background: #f9f9f9;
                font-family: Arial, sans-serif;
            }

                .cp-container h2 {
                    text-align: center;
                    margin-bottom: 20px;
                    color: #333;
                }

            /* ===== FORM GROUP ===== */
            .form-group {
                margin-bottom: 15px;
                position: relative;
            }

            label {
                display: block;
                font-weight: bold;
                margin-bottom: 5px;
                color: #444;
            }

            input[type="password"],
            input[type="text"] {
                width: 100%;
                padding: 8px 35px 8px 8px;
                border: 1px solid #bbb;
                border-radius: 4px;
                font-size: 14px;
            }

            /* ===== EYE BUTTON ===== */
            .toggle-btn {
                position: absolute;
                right: 8px;
                top: 32px;
                cursor: pointer;
                font-size: 13px;
                color: #007bff;
                background: none;
                border: none;
            }

            /* ===== BUTTON ===== */
            .btn-submit {
                width: 100%;
                padding: 10px;
                background: #007bff;
                color: white;
                border: none;
                border-radius: 4px;
                font-size: 15px;
                cursor: pointer;
            }

                .btn-submit:hover {
                    background: #0056b3;
                }

            /* ===== MESSAGES ===== */
            .text-danger {
                color: red;
                font-size: 13px;
            }

            .success-msg {
                background: #d4edda;
                color: #155724;
                padding: 10px;
                margin-bottom: 15px;
                border-radius: 4px;
                text-align: center;
            }

            .error-msg {
                background: #f8d7da;
                color: #721c24;
                padding: 10px;
                margin-bottom: 15px;
                border-radius: 4px;
                text-align: center;
            }
        </style>

        <div id="page-wrapper">


            <div class="main-page">
                <div class="col-md-4 widget-shadow">
                    <div class="cp-container">

                    @* ===== POPUP MESSAGES ===== *@
                    @if (TempData["Success"] != null)
                    {
                        <div class="success-msg">@TempData["Success"]</div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="error-msg">@TempData["Error"]</div>
                    }


                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { style = "color:red" })
                        <div class="form-group">
                            <label>User ID</label>
                            @Html.TextBoxFor(m => m.Email, new { @readonly = "readonly" })
                        </div>


                        <div class="form-group">
                            <label>Old Password</label>
                            @Html.PasswordFor(m => m.OldPassword, new { id = "oldPwd" })
                            <button type="button" class="toggle-btn" onclick="togglePwd('oldPwd')">👁</button>
                            @Html.ValidationMessageFor(m => m.OldPassword, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            <label>New Password</label>
                            @Html.PasswordFor(m => m.NewPassword, new { id = "newPwd" })
                            <button type="button" class="toggle-btn" onclick="togglePwd('newPwd')">👁</button>
                            @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            <label>Confirm Password</label>
                            @Html.PasswordFor(m => m.ConfirmPassword, new { id = "confirmPwd" })
                            <button type="button" class="toggle-btn" onclick="togglePwd('confirmPwd')">👁</button>
                            @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger" })
                        </div>

                        <button type="submit" class="btn-submit">Change Password</button>
                    }
                </div>
        </div>
